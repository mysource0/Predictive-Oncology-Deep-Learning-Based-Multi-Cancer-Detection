# Flask Configuration
SECRET_KEY=your-secret-key-change-this-in-production
FLASK_ENV=development
FLASK_DEBUG=False

# Database
DATABASE_URL=sqlite:///users.db

# Upload Settings
MAX_UPLOAD_SIZE_MB=5
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,bmp

# Gemini AI API Keys (comma-separated, used as fallback if one hits rate limit)
# Get keys from https://aistudio.google.com/apikey
GEMINI_API_KEYS=your-key-1,your-key-2,your-key-3

# Gemini models to try in order (comma-separated, falls back to next if rate-limited)
GEMINI_MODELS=gemini-2.5-pro,gemini-2.5-flash,gemini-2.0-flash,gemini-1.5-pro,gemini-1.5-flash
